# Turso (libSQL) Embedded Replica = Sync 方式の接続情報
# Turso CLI で取得できます:
#   turso db show <db-name> --url        # -> libsql://... を TURSO_DATABASE_URL へ
#   turso db tokens create <db-name>     # -> トークンを TURSO_AUTH_TOKEN へ
#
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env

# リモート Turso の URL（sync_url）。設定すると Sync 方式（ローカルレプリカ＋同期）が有効。
# 例: libsql://my-todo-xxxx.turso.io
# 未設定の場合はローカルレプリカ単体（同期なし）として動作します。
TURSO_DATABASE_URL=

# 認証トークン（Sync 方式で必須）
TURSO_AUTH_TOKEN=

# ローカルに置くレプリカ（SQLite ファイル）のパス。既定は todo.db
# TURSO_SYNC_LOCAL_PATH=todo.db

# 任意: バックグラウンドで自動同期する間隔（秒）。未設定なら読み書きの前後で手動同期。
# TURSO_SYNC_INTERVAL=5

# 任意: リモートに繋げないとき、ローカルへ縮退せず即エラーにする（1 で同期必須）。
# 既定（空）では、繋げない場合はローカルレプリカで縮退起動します。
# TURSO_REQUIRE_SYNC=1

# Flask のセッション署名鍵（本番では推測されにくい値に変更してください）
FLASK_SECRET_KEY=dev-secret-change-me

# 任意: 起動ホスト/ポート/デバッグ
# HOST=127.0.0.1
# PORT=5000
# FLASK_DEBUG=1
